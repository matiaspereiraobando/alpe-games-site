---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameCard from '../components/GameCard.astro';
import { getGamesSorted } from '../lib/registry';

const games = getGamesSorted().slice(0, 6);
---

<BaseLayout title="ALPE Games">
  <section class="hero">
    <h1>ALPE Games</h1>
    <p>
      We ship a new browser-playable prototype every 10–15 days. The goal is
      learning, experimentation, and finding ideas worth expanding—not polish on
      every release.
    </p>
  </section>

  <section>
    <h2>Latest experiments</h2>
    {games.length > 0 ? (
      <div class="game-grid">
        {games.map((game) => (
          <GameCard game={game} />
        ))}
      </div>
    ) : (
      <p>No games published yet. First cycle coming soon.</p>
    )}
    <p style="margin-top: 1.5rem;">
      <a href="/games/">View all games →</a>
    </p>
  </section>
</BaseLayout>
